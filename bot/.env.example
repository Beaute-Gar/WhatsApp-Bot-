#  DJOUSSE TECH EVOLUTION — Configuration du serveur bot
# ═══════════════════════════════════════════════════════════

# Port d'écoute du serveur
PORT=4000

# Ton numéro WhatsApp admin (format international sans le +)
# Exemple Cameroun: 237600000000
ADMIN_NUMBER=237600000000

# URL de ton frontend Vercel (pour CORS)
# Exemple: https://djousse-tech.vercel.app
FRONTEND_URL=https://TON_APP.vercel.app

# Optionnel: clé secrète pour sécuriser l'API
API_SECRET=change_moi_en_production
